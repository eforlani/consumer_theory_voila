# Consumer Preferences: Indifference Curves and the Budget Line


```python
def utility(x, y, alpha):
    return x ** alpha * y ** (1 - alpha)


def optimum_bundle(m, px, py, alpha):
    x_opt = (alpha * m) / px
    y_opt = ((1 - alpha) * m) / py
    return x_opt, y_opt


def plot_consumer(m, px, py, alpha, x_max, y_max, u_levels):
    import numpy as np
    import matplotlib.pyplot as plt

    x = np.linspace(0, x_max, 100)
    y = (m / py) - (px / py) * x
    plt.plot(x, y, label='Budget Line', color='blue')

    for u in u_levels:
        y_indiff = (u / (x ** alpha)) ** (1 / (1 - alpha))
        plt.plot(x, y_indiff, label=f'Indifference Curve U={u}')

    plt.xlim(0, x_max)
    plt.ylim(0, y_max)
    plt.xlabel('X-axis')
    plt.ylabel('Y-axis')
    plt.title('Indifference Curves and Budget Line')
    plt.grid(True)
    plt.legend()
    plt.show()
    
```

```python
# Test call to plot_consumer
plot_consumer(100, 2, 3, 0.5, 50, 50, [10, 20, 30])
```

```python
